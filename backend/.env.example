# Copy this file to .env and fill in values.
# The backend auto-loads .env at startup via python-dotenv.

# ── Summarization model ────────────────────────────────────────────────────
# textrank   → pure Python, no downloads, fast (default)
# distilbart → sshleifer/distilbart-cnn-6-6, ~300 MB, better quality
# flan-t5    → google/flan-t5-small, ~300 MB, fastest transformer
SUMMARIZER_MODEL=textrank

# ── Server ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Gmail OAuth ────────────────────────────────────────────────────────────
# Path to credentials.json downloaded from Google Cloud Console.
# Default: backend/credentials/credentials.json
# GMAIL_CREDENTIALS_PATH=credentials/credentials.json
